#include <WiFi.h>
#include <DNSServer.h>
#include <ESPAsyncWebServer.h>
#include <ESP32Servo.h>

// --- PIN DEFINITIONS ---
const int PIN_LDR_TL = 36; 
const int PIN_LDR_TR = 39; 
const int PIN_LDR_BL = 34; 
const int PIN_LDR_BR = 35; 
const int PIN_VOLTAGE = 32; 
const int PIN_RELAY = 27;   
const int PIN_SERVO_PAN = 18;
const int PIN_SERVO_TILT = 19;

// --- TELEMETRY MATH ---
const float R1 = 10000.0;  
const float R2 = 4700.0;   
const float R_LOAD = 50.0; 

// --- GLOBAL OBJECTS ---
Servo panServo;
Servo tiltServo;
AsyncWebServer server(80);
DNSServer dnsServer;

// --- STATE VARIABLES ---
int currentPan = 90;
int currentTilt = 45;
int targetPan = 90;
int targetTilt = 45;

int autoSpeedDelay = 20;   // Default 20ms per degree in auto mode
int manualSpeedDelay = 5;  // Default 5ms per degree in manual mode

bool isTracking = true;
bool stormMode = false;

// Pump state
bool isPumping = false;
unsigned long pumpStartTime = 0;
const unsigned long PUMP_DURATION = 3000; // 3 seconds

// Sensor data
int ldr_tl = 0, ldr_tr = 0, ldr_bl = 0, ldr_br = 0;
float voltage = 0.0, current = 0.0;

