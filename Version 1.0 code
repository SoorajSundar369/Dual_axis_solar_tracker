void setup() {
  Serial.begin(115200);
  
  // Relay Setup
  pinMode(PIN_RELAY, OUTPUT);
  digitalWrite(PIN_RELAY, LOW);
  
  // Servo Setup
  panServo.attach(PIN_SERVO_PAN);
  tiltServo.attach(PIN_SERVO_TILT);
  panServo.write(currentPan);
  tiltServo.write(currentTilt);

  // WiFi Setup
  WiFi.mode(WIFI_AP);
  WiFi.softAP("Solar Tracker", "99999999");
  dnsServer.start(53, "*", WiFi.softAPIP());

  // Web Server Routes
  server.on("/", HTTP_GET, [](AsyncWebServerRequest *request){ 
      request->send_P(200, "text/html", index_html); 
  });
  
  server.on("/api", HTTP_GET, [](AsyncWebServerRequest *request){
      String json = "{";
      json += "\"v\":" + String(voltage, 2) + ",";
      json += "\"i\":" + String(current, 3) + ",";
      json += "\"cp\":" + String(currentPan) + ",";   // Current physical pan
      json += "\"ct\":" + String(currentTilt) + ",";  // Current physical tilt
      json += "\"tp\":" + String(targetPan) + ",";    // Target pan
      json += "\"tt\":" + String(targetTilt) + ",";   // Target tilt
      json += "\"as\":" + String(autoSpeedDelay) + ",";
      json += "\"ms\":" + String(manualSpeedDelay) + ",";
      json += "\"at\":" + String(isTracking ? "1" : "0") + ",";
      json += "\"sm\":" + String(stormMode ? "1" : "0");
      json += "}";
      request->send(200, "application/json", json);
  });

  server.on("/auto", HTTP_GET, [](AsyncWebServerRequest *request){
      if(request->hasParam("state")) { 
          isTracking = (request->getParam("state")->value() == "1"); 
          stormMode = false; 
      }
      request->send(200);
  });

  server.on("/manual", HTTP_GET, [](AsyncWebServerRequest *request){
      if(request->hasParam("axis") && request->hasParam("val")) {
          String axis = request->getParam("axis")->value();
          int val = request->getParam("val")->value().toInt();
          
          if(axis == "auto_speed") autoSpeedDelay = val;
          else if(axis == "man_speed") manualSpeedDelay = val;
          else {
              isTracking = false; // Disable auto tracking if manual sliders are used
              stormMode = false;
              if(axis == "pan") targetPan = constrain(val, 0, 180);
              if(axis == "tilt") targetTilt = constrain(val, 0, 90);
          }
      }
      request->send(200);
  });

  server.on("/clean", HTTP_GET, [](AsyncWebServerRequest *request){
      // Non-blocking pump trigger
      isPumping = true;
      pumpStartTime = millis();
      digitalWrite(PIN_RELAY, HIGH);
      request->send(200);
  });

  server.on("/storm", HTTP_GET, [](AsyncWebServerRequest *request){
      stormMode = !stormMode; 
      isTracking = false; // Storm overrides tracking
      if(stormMode) { 
          targetPan = 90; 
          targetTilt = 33; // Park at exactly 33 degrees tilt
      }
      request->send(200);
  });

  server.onNotFound([](AsyncWebServerRequest *request){ 
      request->redirect("http://192.168.4.1/"); 
  });
  
  server.begin();
}

void loop() {
  dnsServer.processNextRequest();
  unsigned long currentMillis = millis();
  
  // 1. Non-blocking Pump Management
  if (isPumping && (currentMillis - pumpStartTime >= PUMP_DURATION)) {
      digitalWrite(PIN_RELAY, LOW);
      isPumping = false;
  }

  // 2. Read Sensors (Polled every 50ms to allow ultra-fast tracking reactions)
  static unsigned long lastLDRTime = 0;
  if (currentMillis - lastLDRTime > 50) {
      lastLDRTime = currentMillis;
      
      ldr_tl = analogRead(PIN_LDR_TL); 
      ldr_tr = analogRead(PIN_LDR_TR);
      ldr_bl = analogRead(PIN_LDR_BL); 
      ldr_br = analogRead(PIN_LDR_BR);
      
      float vRaw = (analogRead(PIN_VOLTAGE) * 3.3 / 4095.0);
      voltage = vRaw * ((R1 + R2) / R2);
      current = voltage / R_LOAD;

      // CONTINUOUS CHASER LOGIC (Unlocks the speed bottleneck)
      if(isTracking && !stormMode) {
          int avgTop = (ldr_tl + ldr_tr) / 2;
          int avgBot = (ldr_bl + ldr_br) / 2;
          int avgLeft = (ldr_tl + ldr_bl) / 2;
          int avgRight = (ldr_tr + ldr_br) / 2;
          
          int diffV = avgTop - avgBot;
          int diffH = avgLeft - avgRight;
          int tol = 120; // Hysteresis to prevent jitter

          // Tilt Logic
          if (abs(diffV) > tol) {
              if (diffV > 0) targetTilt = 90; // Command full sweep up
              else targetTilt = 0;            // Command full sweep down
          } else {
              targetTilt = currentTilt;       // Halt instantly when balanced
          }

          // Pan Logic 
          if (abs(diffH) > tol) {
              if (diffH > 0) targetPan = 180; // Command full sweep right
              else targetPan = 0;             // Command full sweep left
          } else {
              targetPan = currentPan;         // Halt instantly when balanced
          }
      }
  }

  // 3. Smooth Non-blocking Servo Sweep
  static unsigned long lastServoTime = 0;
  
  // The crucial check that uses different speeds based on the mode!
  int activeDelay = isTracking ? autoSpeedDelay : manualSpeedDelay;
  if (activeDelay < 1) activeDelay = 1; // Prevent division by zero

  unsigned long timePassed = currentMillis - lastServoTime;
  if (timePassed >= activeDelay) {
      // Calculate exactly how many steps we should move based on elapsed time.
      // This guarantees the speed slider is perfectly accurate even if the web server delays the loop.
      int steps = timePassed / activeDelay;
      lastServoTime = currentMillis - (timePassed % activeDelay); // Keep remainder for perfect mathematical timing
      
      if (steps > 5) steps = 5; // Cap maximum steps to prevent violent jerks

      bool moved = false;

      // Step pan towards the target
      if (currentPan < targetPan) { 
          currentPan += steps; 
          if (currentPan > targetPan) currentPan = targetPan;
          moved = true; 
      }
      else if (currentPan > targetPan) { 
          currentPan -= steps; 
          if (currentPan < targetPan) currentPan = targetPan;
          moved = true; 
      }
      
      // Step tilt towards the target
      if (currentTilt < targetTilt) { 
          currentTilt += steps; 
          if (currentTilt > targetTilt) currentTilt = targetTilt;
          moved = true; 
      }
      else if (currentTilt > targetTilt) { 
          currentTilt -= steps; 
          if (currentTilt < targetTilt) currentTilt = targetTilt;
          moved = true; 
      }

      // Write to servo
      if (moved) {
          panServo.write(currentPan);
          tiltServo.write(currentTilt);
      }
  }
}
