  #include <WiFi.h>
  #include <DNSServer.h>
  #include <ESPAsyncWebServer.h>
  #include <ESP32Servo.h>

  // --- PIN DEFINITIONS ---
  const int PIN_LDR_TL = 36; 
  const int PIN_LDR_TR = 39; 
  const int PIN_LDR_BL = 34; 
  const int PIN_LDR_BR = 35; 
  const int PIN_VOLTAGE = 32; 
  const int PIN_RELAY = 27;   
  const int PIN_SERVO_PAN = 18;
  const int PIN_SERVO_TILT = 19;

  // --- RELAY LOGIC CONFIGURATION ---
  const int RELAY_ON = HIGH; 
  const int RELAY_OFF = LOW; 

  // --- TELEMETRY MATH ---
  const float R1 = 10000.0;  
  const float R2 = 4700.0;   
  const float R_LOAD = 50.0; 

  // --- GLOBAL OBJECTS ---
  Servo panServo;
  Servo tiltServo;
  AsyncWebServer server(80);
  DNSServer dnsServer;

  // --- STATE VARIABLES ---
  int currentPan = 90;
  int currentTilt = 45;
  int targetPan = 90;
  int targetTilt = 45;

  int autoSpeedDelay = 20;   
  int manualSpeedDelay = 5;  
  int washSpeedDelay = 20; // Dynamic speed for the wash cycle

  bool isTracking = true;
  bool stormMode = false;

  // --- ADVANCED WASH STATE MACHINE ---
  bool isCleaningMode = false;
  int cleanState = 0;
  bool wasTrackingBeforeClean = false;

  // Sensor data
  int ldr_tl = 0, ldr_tr = 0, ldr_bl = 0, ldr_br = 0;
  float voltage = 0.0, current = 0.0;

  // --- DASHBOARD HTML (CRISP WHITE iOS STYLE) ---
  const char index_html[] PROGMEM = R"rawcanvas(
  <!DOCTYPE html>
  <html lang="en">
  <head>
      <meta charset="UTF-8">
      <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
      <title>Solar Pro Tracker</title>
      <style>
          * { margin: 0; padding: 0; box-sizing: border-box; -webkit-tap-highlight-color: transparent; font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif; }
          body { background: #F2F2F7; color: #1C1C1E; padding: 20px; padding-bottom: 120px; }
          
          header { margin: 10px 0 25px 0; display: flex; justify-content: space-between; align-items: center; }
          h1 { font-size: 32px; font-weight: 800; letter-spacing: -1px; }
          .status { font-size: 13px; color: #8E8E93; font-weight: 600; display: flex; align-items: center; gap: 6px; }
          .dot { width: 10px; height: 10px; background: #34C759; border-radius: 50%; box-shadow: 0 0 8px rgba(52,199,89,0.4); }
          
          /* Tabs */
          .tab-bar { background: #E5E5EA; padding: 4px; border-radius: 12px; display: flex; margin-bottom: 25px; }
          .tab { flex: 1; padding: 10px; text-align: center; font-size: 14px; font-weight: 600; cursor: pointer; border-radius: 10px; transition: 0.2s; color: #8E8E93; }
          .tab.active { background: #FFFFFF; color: #000000; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
          .section { display: none; }
          .section.active { display: block; }

          /* Cards */
          .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-bottom: 15px; }
          .card { background: #FFFFFF; border-radius: 24px; padding: 20px; box-shadow: 0 4px 20px rgba(0,0,0,0.04); border: 1px solid rgba(0,0,0,0.02); margin-bottom: 15px; }
          .label { font-size: 11px; font-weight: 700; color: #8E8E93; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
          .val { font-size: 28px; font-weight: 700; color: #1C1C1E; }
          .unit { font-size: 14px; font-weight: 500; color: #8E8E93; }

          /* Smooth Gauges */
          .gauge-card { background: #FFFFFF; border-radius: 24px; padding: 20px 15px; border: 1px solid rgba(0,0,0,0.02); text-align: center; box-shadow: 0 4px 20px rgba(0,0,0,0.04); }
          .gauge-container { position: relative; width: 100%; max-width: 140px; margin: 0 auto; }
          .gauge-svg { width: 100%; display: block; overflow: visible; }
          .gauge-bg { fill: none; stroke: #E5E5EA; stroke-width: 10; stroke-linecap: round; }
          .gauge-progress { fill: none; stroke: #34C759; stroke-width: 10; stroke-linecap: round; stroke-dasharray: 100; transition: stroke-dashoffset 0.1s linear; }
          .gauge-center { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -40%); text-align: center; width: 100%; }
          .gauge-val { font-size: 26px; font-weight: 800; color: #1C1C1E; }
          .gauge-minmax { display: flex; justify-content: space-between; padding: 0 10px; margin-top: -10px; font-size: 11px; color: #8E8E93; font-weight: 600; }

          /* Sliders */
          .ios-slider { -webkit-appearance: none; width: 100%; height: 6px; background: #E5E5EA; border-radius: 5px; outline: none; margin-top: 15px; margin-bottom: 10px; }
          .ios-slider::-webkit-slider-thumb { -webkit-appearance: none; appearance: none; width: 28px; height: 28px; border-radius: 50%; background: #FFFFFF; cursor: pointer; box-shadow: 0 2px 6px rgba(0,0,0,0.2); border: 1px solid #E5E5EA; }

          /* Buttons */
          .btn { width: 100%; padding: 18px; border-radius: 20px; font-weight: 700; font-size: 16px; border: none; cursor: pointer; transition: 0.1s; margin-bottom: 12px; }
          .btn-blue { background: #007AFF; color: #FFFFFF; }
          .btn-green { background: #34C759; color: #FFFFFF; }
          .btn-gray { background: #E5E5EA; color: #1C1C1E; }
          .btn-red { background: #FF3B30; color: #FFFFFF; }
          .btn:active { transform: scale(0.97); opacity: 0.9; }

          /* Wash Status Box */
          #clean-status { display: none; background: #E6F2FF; border-radius: 20px; padding: 18px; margin-bottom: 15px; border: 1px solid #007AFF; box-shadow: 0 4px 15px rgba(0,122,255,0.1); }
          #clean-bar-container { width: 100%; height: 10px; background: #FFFFFF; border-radius: 5px; overflow: hidden; margin-top: 8px; border: 1px solid rgba(0,0,0,0.05); }
          #clean-bar { width: 0%; height: 100%; background: #007AFF; transition: width 0.4s ease; }

          /* Footer */
          .footer { position: fixed; bottom: 25px; left: 20px; right: 20px; background: rgba(255, 255, 255, 0.9); backdrop-filter: blur(20px); border-radius: 35px; padding: 20px; display: flex; justify-content: space-around; box-shadow: 0 10px 40px rgba(0,0,0,0.1); z-index: 100; border: 1px solid rgba(0,0,0,0.05); }
          .footer-val { font-size: 22px; font-weight: 800; color: #1C1C1E; }
          .footer-label { font-size: 10px; font-weight: 700; color: #8E8E93; text-transform: uppercase; text-align: center; margin-bottom: 2px;}
      </style>
  </head>
  <body>
      <header>
          <h1>Solar Pro</h1>
          <div class="status"><div class="dot" id="dot"></div><span id="stat-text">Active</span></div>
      </header>

      <div class="tab-bar">
          <div class="tab active" onclick="switchTab('main')">Overview</div>
          <div class="tab" onclick="switchTab('adv')">Motion & Tuning</div>
      </div>

      <!-- OVERVIEW TAB -->
      <div id="sec-main" class="section active">
          <div class="grid">
              <div class="card"><div class="label">Voltage</div><div class="val" id="v">0.00 <span class="unit">V</span></div></div>
              <div class="card"><div class="label">Current</div><div class="val" id="i" style="color:#007AFF;">0.00 <span class="unit">A</span></div></div>
          </div>

          <div id="clean-status">
              <div style="display:flex; justify-content:space-between; align-items:center;">
                  <span style="font-size:11px; font-weight:800; color:#007AFF; text-transform:uppercase;">Washing Panel</span>
                  <span id="clean-txt" style="font-size:12px; font-weight:700; color:#1C1C1E;">Initializing...</span>
              </div>
              <div id="clean-bar-container"><div id="clean-bar"></div></div>
          </div>

          <div class="card">
              <button id="auto-btn" class="btn btn-green" onclick="toggleAuto()">AUTO TRACKING: ON</button>
              <hr style="border:0; border-top:1px solid #E5E5EA; margin:15px 0;">
              <button class="btn btn-blue" id="clean-btn" onclick="triggerClean()">Clean Panel Now</button>
              <button id="storm-btn" class="btn btn-red" onclick="triggerStorm()">Activate Storm Mode</button>
          </div>
      </div>

      <!-- MOTION & TUNING TAB -->
      <div id="sec-adv" class="section">
          <div class="grid">
              <!-- Pan Control -->
              <div class="gauge-card">
                  <div class="label" style="text-align:center;">Pan Axis</div>
                  <div class="gauge-container">
                      <svg class="gauge-svg" viewBox="0 0 100 100">
                          <path class="gauge-bg" d="M 20 80 A 42 42 0 1 1 80 80" />
                          <path id="pan-path" class="gauge-progress" d="M 20 80 A 42 42 0 1 1 80 80" pathLength="100" stroke-dashoffset="50" />
                      </svg>
                      <div class="gauge-center"><div class="gauge-val" id="pan-txt">90&deg;</div></div>
                  </div>
                  <div class="gauge-minmax"><span>0</span><span>180</span></div>
                  <input type="range" id="pSlider" class="ios-slider" min="0" max="180" value="90" 
                        oninput="slideUpdate('pan', this.value)" onchange="slideCommit('pan', this.value)">
              </div>
              
              <!-- Tilt Control -->
              <div class="gauge-card">
                  <div class="label" style="text-align:center;">Tilt Axis</div>
                  <div class="gauge-container">
                      <svg class="gauge-svg" viewBox="0 0 100 100">
                          <path class="gauge-bg" d="M 20 80 A 42 42 0 1 1 80 80" />
                          <path id="tilt-path" class="gauge-progress" d="M 20 80 A 42 42 0 1 1 80 80" pathLength="100" stroke-dashoffset="50" />
                      </svg>
                      <div class="gauge-center"><div class="gauge-val" id="tilt-txt">45&deg;</div></div>
                  </div>
                  <div class="gauge-minmax"><span>0</span><span>90</span></div>
                  <input type="range" id="tSlider" class="ios-slider" min="0" max="90" value="45" 
                        oninput="slideUpdate('tilt', this.value)" onchange="slideCommit('tilt', this.value)">
              </div>
          </div>

          <!-- Speeds -->
          <div class="card">
              <div class="label" style="margin-bottom:15px;">Servo Delay Tuning</div>
              
              <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                  <span style="font-size:14px; font-weight:600;">Auto Tracking Speed</span>
                  <span id="as-val" style="font-weight:700; color:#007AFF;">20ms</span>
              </div>
              <input type="range" id="asSlider" class="ios-slider" min="2" max="100" value="20" 
                    oninput="slideUpdate('auto_speed', this.value)" onchange="slideCommit('auto_speed', this.value)">
              
              <div style="display:flex; justify-content:space-between; margin-bottom:5px; margin-top:15px;">
                  <span style="font-size:14px; font-weight:600;">Manual Control Speed</span>
                  <span id="ms-val" style="font-weight:700; color:#007AFF;">5ms</span>
              </div>
              <input type="range" id="msSlider" class="ios-slider" min="2" max="100" value="5" 
                    oninput="slideUpdate('man_speed', this.value)" onchange="slideCommit('man_speed', this.value)">
              
              <p style="font-size:11px; color:#8E8E93; text-align:center; margin-top:10px;">Lower ms = Faster turn. Higher ms = Smoother turn.</p>
          </div>
      </div>

      <!-- Bottom Footer Status -->
      <div class="footer">
          <div style="text-align:center;"><div class="footer-label">Current Pan</div><div class="footer-val" id="fp">90&deg;</div></div>
          <div style="width:1px; background:#E5E5EA; height:30px;"></div>
          <div style="text-align:center;"><div class="footer-label">Current Tilt</div><div class="footer-val" id="ft">45&deg;</div></div>
      </div>

      <script>
          let uiLocks = { pan: false, tilt: false, auto_speed: false, man_speed: false };
          let autoState = true;

          // UI Tabs
          function switchTab(t) {
              document.querySelectorAll('.tab').forEach((e,i) => e.classList.toggle('active', (i==0 && t=='main') || (i==1 && t=='adv')));
              document.querySelectorAll('.section').forEach((e,i) => e.classList.toggle('active', (i==0 && t=='main') || (i==1 && t=='adv')));
          }

          // SVG Arc Math
          function updateGaugeUI(axis, val, max) {
              const path = document.getElementById(axis + '-path');
              const txt = document.getElementById(axis + '-txt');
              const offset = 100 - ((val / max) * 100);
              path.style.strokeDashoffset = offset;
              txt.innerHTML = Math.round(val) + '&deg;';
          }

          // Single-Flight Queue Setup
          let pendingRequests = {};
          let isFetching = false;
          function processQueue() {
              if (isFetching) return;
              let keys = Object.keys(pendingRequests);
              if (keys.length === 0) return;
              
              let axis = keys[0];
              let val = pendingRequests[axis];
              delete pendingRequests[axis];

              isFetching = true;
              fetch('/manual?axis=' + axis + '&val=' + val)
                  .then(() => { isFetching = false; processQueue(); })
                  .catch(() => { isFetching = false; processQueue(); });
          }

          // Updates UI visually while dragging
          function slideUpdate(axis, val) {
              uiLocks[axis] = true;
              if(axis === 'pan') { updateGaugeUI('pan', val, 180); autoState = false; renderAutoBtn(); }
              if(axis === 'tilt') { updateGaugeUI('tilt', val, 90); autoState = false; renderAutoBtn(); }
              if(axis === 'auto_speed') document.getElementById('as-val').innerText = val + 'ms';
              if(axis === 'man_speed') document.getElementById('ms-val').innerText = val + 'ms';

              pendingRequests[axis] = val;
              processQueue();
          }

          // Sends exact value on finger lift
          function slideCommit(axis, val) {
              pendingRequests[axis] = val;
              processQueue();
              setTimeout(() => { uiLocks[axis] = false; }, 400); 
          }

          // Button Actions
          function toggleAuto() {
              autoState = !autoState;
              fetch('/auto?state=' + (autoState ? '1' : '0'));
              renderAutoBtn();
          }

          function renderAutoBtn() {
              const btn = document.getElementById('auto-btn');
              if(autoState) {
                  btn.className = "btn btn-green";
                  btn.innerText = "AUTO TRACKING: ON";
              } else {
                  btn.className = "btn btn-gray";
                  btn.innerText = "MANUAL CONTROL: ON";
              }
          }

          function triggerClean() {
              fetch('/clean'); 
          }

          function triggerStorm() {
              fetch('/storm'); 
          }

          // Fetch loop
          function fetchData() {
              fetch('/api').then(r => r.json()).then(d => {
                  document.getElementById('v').innerHTML = d.v.toFixed(2) + ' <span class="unit">V</span>';
                  document.getElementById('i').innerHTML = d.i.toFixed(3) + ' <span class="unit">A</span>';
                  
                  // UI: Wash Cycle Progress (Now 19 states)
                  if(d.cln === 1) {
                      document.getElementById('clean-status').style.display = 'block';
                      let progress = (d.cls / 19.0) * 100;
                      document.getElementById('clean-bar').style.width = progress + '%';
                      
                      let txt = "Positioning...";
                      if(d.cls === 2) txt = "Spraying (1/2)...";
                      if(d.cls === 3) txt = "Pausing...";
                      if(d.cls === 4) txt = "Spraying (2/2)...";
                      if(d.cls === 5) txt = "Soaking (2s)...";
                      if(d.cls === 6 || d.cls === 7) txt = "Tilt Wash (Slow)...";
                      if(d.cls === 8 || d.cls === 9) txt = "Tilt Wash (Fast)...";
                      if(d.cls === 10) txt = "Pausing (1s)...";
                      if(d.cls >= 11 && d.cls <= 13) txt = "Diagonal Wash (1/2)...";
                      if(d.cls === 14) txt = "Pausing (1s)...";
                      if(d.cls >= 15 && d.cls <= 18) txt = "Diagonal Wash (2/2)...";
                      if(d.cls >= 19) txt = "Finishing...";
                      document.getElementById('clean-txt').innerText = txt;
                      
                      document.getElementById('clean-btn').innerText = "Washing in Progress...";
                      document.getElementById('clean-btn').className = "btn btn-gray";
                      document.getElementById('clean-btn').disabled = true;
                  } else {
                      document.getElementById('clean-status').style.display = 'none';
                      document.getElementById('clean-btn').innerText = "Clean Panel Now";
                      document.getElementById('clean-btn').className = "btn btn-blue";
                      document.getElementById('clean-btn').disabled = false;
                  }

                  // UI: Tracking State
                  if(d.cln === 0) { // Only sync auto button if not cleaning
                      autoState = d.at === 1;
                      renderAutoBtn();
                  }

                  document.getElementById('fp').innerHTML = d.cp + '&deg;';
                  document.getElementById('ft').innerHTML = d.ct + '&deg;';

                  if(!uiLocks.pan) { document.getElementById('pSlider').value = d.tp; updateGaugeUI('pan', d.cp, 180); }
                  if(!uiLocks.tilt) { document.getElementById('tSlider').value = d.tt; updateGaugeUI('tilt', d.ct, 90); }
                  if(!uiLocks.auto_speed) { document.getElementById('asSlider').value = d.as; document.getElementById('as-val').innerText = d.as + 'ms'; }
                  if(!uiLocks.man_speed) { document.getElementById('msSlider').value = d.ms; document.getElementById('ms-val').innerText = d.ms + 'ms'; }

                  document.getElementById('storm-btn').innerText = d.sm ? "Exit Storm Mode" : "Activate Storm Mode";
                  
                  document.getElementById('dot').style.background = '#34C759';
                  document.getElementById('dot').style.boxShadow = '0 0 8px rgba(52,199,89,0.4)';
                  document.getElementById('stat-text').innerText = 'System Active';
              }).catch(() => {
                  document.getElementById('dot').style.background = '#FF3B30';
                  document.getElementById('dot').style.boxShadow = '0 0 8px rgba(255,59,48,0.4)';
                  document.getElementById('stat-text').innerText = 'Offline / Reconnecting';
              });
          }

          setInterval(fetchData, 300); // UI Refresh Rate
          fetchData();
      </script>
  </body>
  </html>
  )rawcanvas";

  void setup() {
    Serial.begin(115200);
    
    // Relay Setup
    pinMode(PIN_RELAY, OUTPUT);
    digitalWrite(PIN_RELAY, RELAY_OFF);
    
    // Servo Setup
    panServo.attach(PIN_SERVO_PAN);
    tiltServo.attach(PIN_SERVO_TILT);
    panServo.write(currentPan);
    tiltServo.write(currentTilt);

    // WiFi Setup
    WiFi.mode(WIFI_AP);
    WiFi.softAP("Solar Tracker", "99999999");
    dnsServer.start(53, "*", WiFi.softAPIP());

    // Web Server Routes
    server.on("/", HTTP_GET, [](AsyncWebServerRequest *request){ 
        request->send_P(200, "text/html", index_html); 
    });
    
    server.on("/api", HTTP_GET, [](AsyncWebServerRequest *request){
        String json = "{";
        json += "\"v\":" + String(voltage, 2) + ",";
        json += "\"i\":" + String(current, 3) + ",";
        json += "\"cp\":" + String(currentPan) + ",";
        json += "\"ct\":" + String(currentTilt) + ",";
        json += "\"tp\":" + String(targetPan) + ",";
        json += "\"tt\":" + String(targetTilt) + ",";
        json += "\"as\":" + String(autoSpeedDelay) + ",";
        json += "\"ms\":" + String(manualSpeedDelay) + ",";
        json += "\"at\":" + String(isTracking ? "1" : "0") + ",";
        json += "\"sm\":" + String(stormMode ? "1" : "0") + ",";
        json += "\"cln\":" + String(isCleaningMode ? "1" : "0") + ",";
        json += "\"cls\":" + String(cleanState);
        json += "}";
        request->send(200, "application/json", json);
    });

    server.on("/auto", HTTP_GET, [](AsyncWebServerRequest *request){
        if(request->hasParam("state")) { 
            isTracking = (request->getParam("state")->value() == "1"); 
            stormMode = false;
            if(isCleaningMode) { isCleaningMode = false; cleanState = 0; digitalWrite(PIN_RELAY, RELAY_OFF); } 
        }
        request->send(200);
    });

    server.on("/manual", HTTP_GET, [](AsyncWebServerRequest *request){
        if(request->hasParam("axis") && request->hasParam("val")) {
            String axis = request->getParam("axis")->value();
            int val = request->getParam("val")->value().toInt();
            
            if(axis == "auto_speed") autoSpeedDelay = val;
            else if(axis == "man_speed") manualSpeedDelay = val;
            else {
                isTracking = false;
                stormMode = false;
                if(isCleaningMode) { isCleaningMode = false; cleanState = 0; digitalWrite(PIN_RELAY, RELAY_OFF); }
                if(axis == "pan") targetPan = constrain(val, 0, 180);
                if(axis == "tilt") targetTilt = constrain(val, 0, 90);
            }
        }
        request->send(200);
    });

    server.on("/clean", HTTP_GET, [](AsyncWebServerRequest *request){
        if(!isCleaningMode) {
            isCleaningMode = true;
            cleanState = 1;
            wasTrackingBeforeClean = isTracking;
            isTracking = false;
            stormMode = false;
            targetPan = 75; // Initial Pan Wash Position
            targetTilt = 90; // Initial Tilt Wash Position
            washSpeedDelay = 20; // Swift positioning speed
        }
        request->send(200);
    });

    server.on("/storm", HTTP_GET, [](AsyncWebServerRequest *request){
        stormMode = !stormMode; 
        isTracking = false;
        if(isCleaningMode) { isCleaningMode = false; cleanState = 0; digitalWrite(PIN_RELAY, RELAY_OFF); }
        
        if(stormMode) { 
            targetPan = 90; 
            targetTilt = 33; 
        }
        request->send(200);
    });

    server.onNotFound([](AsyncWebServerRequest *request){ 
        request->redirect("http://192.168.4.1/"); 
    });
    
    server.begin();
  }

  void loop() {
    dnsServer.processNextRequest();
    unsigned long currentMillis = millis();

    // 1. --- ADVANCED WASH STATE MACHINE (Custom Sequence) ---
    static unsigned long washPauseTimer = 0;
    if (isCleaningMode) {
        // Advance to next state ONLY when servos reach their current target
        if (currentPan == targetPan && currentTilt == targetTilt) {
            switch(cleanState) {
                case 1: // Reached 75 Pan, 90 Tilt. Start pump (Spray 1).
                    digitalWrite(PIN_RELAY, RELAY_ON); 
                    washPauseTimer = currentMillis; 
                    cleanState = 2; 
                    break;
                    
                case 2: // Wait 2s for spray 1
                    if (currentMillis - washPauseTimer >= 2000) {
                        digitalWrite(PIN_RELAY, RELAY_OFF); // Stop pump
                        washPauseTimer = currentMillis;
                        cleanState = 3; 
                    }
                    break;
                    
                case 3: // Wait 500ms pause
                    if (currentMillis - washPauseTimer >= 500) {
                        digitalWrite(PIN_RELAY, RELAY_ON); // Start pump (Spray 2)
                        washPauseTimer = currentMillis;
                        cleanState = 4; 
                    }
                    break;
                    
                case 4: // Wait 2s for spray 2
                    if (currentMillis - washPauseTimer >= 2000) {
                        digitalWrite(PIN_RELAY, RELAY_OFF); // Pump completely done
                        washPauseTimer = currentMillis;
                        cleanState = 5; 
                    }
                    break;
                    
                case 5: // Delay 2s before shaking
                    if (currentMillis - washPauseTimer >= 2000) {
                        targetTilt = 70; 
                        washSpeedDelay = 35; // Slow Speed
                        cleanState = 6; 
                    }
                    break;
                    
                case 6: // Reached 70 Tilt. Return to 90.
                    targetTilt = 90; 
                    cleanState = 7; 
                    break;
                    
                case 7: // Reached 90 Tilt. Switch to FAST TILT.
                    targetTilt = 70; 
                    washSpeedDelay = 12; // Fast Speed
                    cleanState = 8; 
                    break;
                    
                case 8: // Reached 70 Tilt. Return to 90. 
                    targetTilt = 90; 
                    cleanState = 9; 
                    break;
                    
                case 9: // Reached 90 Tilt. Start 1 SEC DELAY.
                    washPauseTimer = currentMillis;
                    cleanState = 10;
                    break;

                case 10: // 1s delay done. VERY FAST PAN & TILT (1st time)
                    if (currentMillis - washPauseTimer >= 1000) {
                        targetTilt = 70; 
                        targetPan = 60;
                        washSpeedDelay = 4; // Max Speed
                        cleanState = 11;
                    }
                    break;

                case 11: // Reached 70 Tilt, 60 Pan. Return 90.
                    targetTilt = 90; 
                    targetPan = 90;
                    cleanState = 12;
                    break;
                    
                case 12: // Reached 90 Tilt, 90 Pan. VERY FAST PAN & TILT (2nd time)
                    targetTilt = 70;
                    targetPan = 60;
                    cleanState = 13;
                    break;
                    
                case 13: // Reached 70 Tilt, 60 Pan. Return to 90.
                    targetTilt = 90;
                    targetPan = 90;
                    cleanState = 14;
                    break;

                case 14: // Reached 90 Tilt, 90 Pan. START 1 SEC DELAY.
                    washPauseTimer = currentMillis;
                    cleanState = 15;
                    break;

                case 15: // 1s delay done. VERY FAST PAN & TILT (3rd time)
                    if (currentMillis - washPauseTimer >= 1000) {
                        targetTilt = 70; 
                        targetPan = 60;
                        cleanState = 16;
                    }
                    break;

                case 16: // Reached 70 Tilt, 60 Pan. Return 90.
                    targetTilt = 90; 
                    targetPan = 90;
                    cleanState = 17;
                    break;
                    
                case 17: // Reached 90 Tilt, 90 Pan. VERY FAST PAN & TILT (4th time)
                    targetTilt = 70;
                    targetPan = 60;
                    cleanState = 18;
                    break;
                    
                case 18: // Reached 70 Tilt, 60 Pan. Return pan to center (75) & tilt 90.
                    targetTilt = 90;
                    targetPan = 75;
                    cleanState = 19;
                    break;

                case 19: // Finish and restore previous state
                    isCleaningMode = false; 
                    cleanState = 0; 
                    isTracking = wasTrackingBeforeClean; // Restore tracking if it was ON
                    break;
            }
        }
    }

    // 2. Read Sensors
    static unsigned long lastLDRTime = 0;
    if (currentMillis - lastLDRTime > 50) {
        lastLDRTime = currentMillis;
        
        ldr_tl = analogRead(PIN_LDR_TL); 
        ldr_tr = analogRead(PIN_LDR_TR);
        ldr_bl = analogRead(PIN_LDR_BL); 
        ldr_br = analogRead(PIN_LDR_BR);
        
        float vRaw = (analogRead(PIN_VOLTAGE) * 3.3 / 4095.0);
        voltage = vRaw * ((R1 + R2) / R2);
        current = voltage / R_LOAD;

        // Auto Tracking Logic 
        if(isTracking && !stormMode && !isCleaningMode) {
            int avgTop = (ldr_tl + ldr_tr) / 2;
            int avgBot = (ldr_bl + ldr_br) / 2;
            int avgLeft = (ldr_tl + ldr_bl) / 2;
            int avgRight = (ldr_tr + ldr_br) / 2;
            
            int diffV = avgTop - avgBot;
            int diffH = avgLeft - avgRight;
            int tol = 120; // Hysteresis

            if (abs(diffV) > tol) {
                if (diffV > 0) targetTilt = 90; 
                else targetTilt = 0;            
            } else {
                targetTilt = currentTilt;       
            }

            if (abs(diffH) > tol) {
                if (diffH > 0) targetPan = 180; 
                else targetPan = 0;             
            } else {
                targetPan = currentPan;         
            }
        }
    }

    // 3. Smooth Step-Chasing Motor Logic
    static unsigned long lastServoTime = 0;
    int activeDelay = isTracking ? autoSpeedDelay : manualSpeedDelay;
    
    // Override speed if washing
    if (isCleaningMode) activeDelay = washSpeedDelay; 
    if (activeDelay < 1) activeDelay = 1;

    unsigned long timePassed = currentMillis - lastServoTime;
    if (timePassed >= activeDelay) {
        int steps = timePassed / activeDelay;
        lastServoTime = currentMillis - (timePassed % activeDelay); 
        
        if (steps > 5) steps = 5; 
        bool moved = false;

        if (currentPan < targetPan) { currentPan += steps; if (currentPan > targetPan) currentPan = targetPan; moved = true; }
        else if (currentPan > targetPan) { currentPan -= steps; if (currentPan < targetPan) currentPan = targetPan; moved = true; }
        
        if (currentTilt < targetTilt) { currentTilt += steps; if (currentTilt > targetTilt) currentTilt = targetTilt; moved = true; }
        else if (currentTilt > targetTilt) { currentTilt -= steps; if (currentTilt < targetTilt) currentTilt = targetTilt; moved = true; }

        if (moved) {
            panServo.write(currentPan);
            tiltServo.write(currentTilt);
        }
    }
  }
